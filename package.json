{
  "name": "vitrio",
  "version": "0.1.2",
  "description": "Cross-browser liquid-glass refraction (Chrome / Safari / Firefox). Real optical displacement with magnification, chromatic aberration and a normal-based specular highlight. Zero dependencies. JS class + <liquid-glass> web component + React/Vue wrappers.",
  "type": "module",
  "main": "dist/vitrio.cjs",
  "module": "dist/vitrio.esm.js",
  "unpkg": "dist/vitrio.umd.min.js",
  "jsdelivr": "dist/vitrio.umd.min.js",
  "types": "dist/vitrio.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vitrio.d.ts",
      "import": "./dist/vitrio.esm.js",
      "require": "./dist/vitrio.cjs",
      "default": "./dist/vitrio.esm.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.esm.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.esm.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.esm.js",
      "require": "./dist/vue.cjs",
      "default": "./dist/vue.esm.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "!dist/demo*",
    "src",
    "!src/demo.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": true,
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json",
    "build:esm": "esbuild src/vitrio.ts --bundle --format=esm --sourcemap --outfile=dist/vitrio.esm.js",
    "build:esm:min": "esbuild src/vitrio.ts --bundle --format=esm --minify --sourcemap --outfile=dist/vitrio.esm.min.js",
    "build:cjs": "esbuild src/vitrio.ts --bundle --format=cjs --sourcemap --outfile=dist/vitrio.cjs",
    "build:umd": "esbuild src/umd-entry.ts --bundle --format=iife --sourcemap --outfile=dist/vitrio.umd.js",
    "build:umd:min": "esbuild src/umd-entry.ts --bundle --format=iife --minify --sourcemap --outfile=dist/vitrio.umd.min.js",
    "build:react": "esbuild src/react.ts --bundle --format=esm --external:react --sourcemap --outfile=dist/react.esm.js",
    "build:react:cjs": "esbuild src/react.ts --bundle --format=cjs --external:react --sourcemap --outfile=dist/react.cjs",
    "build:vue": "esbuild src/vue.ts --bundle --format=esm --external:vue --sourcemap --outfile=dist/vue.esm.js",
    "build:vue:cjs": "esbuild src/vue.ts --bundle --format=cjs --external:vue --sourcemap --outfile=dist/vue.cjs",
    "build:demo": "esbuild src/demo.ts --bundle --format=iife --minify --outfile=dist/demo.min.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run typecheck && npm run build:esm && npm run build:esm:min && npm run build:cjs && npm run build:umd && npm run build:umd:min && npm run build:react && npm run build:react:cjs && npm run build:vue && npm run build:vue:cjs && npm run build:demo && npm run build:types",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "liquid-glass",
    "glassmorphism",
    "refraction",
    "displacement-map",
    "feDisplacementMap",
    "svg-filter",
    "frosted-glass",
    "lens",
    "chromatic-aberration",
    "web-component",
    "react",
    "vue",
    "ui",
    "effect"
  ],
  "author": "Eamon Liu (https://github.com/eamonliu)",
  "license": "MIT",
  "homepage": "https://github.com/eamonliu/vitrio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eamonliu/vitrio.git"
  },
  "bugs": {
    "url": "https://github.com/eamonliu/vitrio/issues"
  },
  "peerDependencies": {
    "react": ">=16.8",
    "vue": ">=3.2"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "esbuild": "^0.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.2",
    "vue": "^3.5.35"
  }
}
