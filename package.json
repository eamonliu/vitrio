{
  "name": "vitrio",
  "version": "0.1.1",
  "description": "Cross-browser liquid-glass refraction (Chrome / Safari / Firefox). Real optical displacement with magnification, chromatic aberration and a normal-based specular highlight. Zero dependencies. JS class + <liquid-glass> web component.",
  "type": "module",
  "main": "dist/vitrio.cjs",
  "module": "dist/vitrio.esm.js",
  "unpkg": "dist/vitrio.umd.min.js",
  "jsdelivr": "dist/vitrio.umd.min.js",
  "types": "dist/vitrio.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vitrio.d.ts",
      "import": "./dist/vitrio.esm.js",
      "require": "./dist/vitrio.cjs",
      "default": "./dist/vitrio.esm.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "!dist/demo*",
    "src",
    "!src/demo.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/umd-entry.*",
    "**/*.umd.js",
    "**/*.umd.min.js"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json",
    "build:esm": "esbuild src/vitrio.ts --bundle --format=esm --sourcemap --outfile=dist/vitrio.esm.js",
    "build:esm:min": "esbuild src/vitrio.ts --bundle --format=esm --minify --sourcemap --outfile=dist/vitrio.esm.min.js",
    "build:cjs": "esbuild src/vitrio.ts --bundle --format=cjs --sourcemap --outfile=dist/vitrio.cjs",
    "build:umd": "esbuild src/umd-entry.ts --bundle --format=iife --sourcemap --outfile=dist/vitrio.umd.js",
    "build:umd:min": "esbuild src/umd-entry.ts --bundle --format=iife --minify --sourcemap --outfile=dist/vitrio.umd.min.js",
    "build:demo": "esbuild src/demo.ts --bundle --format=iife --minify --outfile=dist/demo.min.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run typecheck && npm run build:esm && npm run build:esm:min && npm run build:cjs && npm run build:umd && npm run build:umd:min && npm run build:demo && npm run build:types",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "liquid-glass",
    "glassmorphism",
    "refraction",
    "displacement-map",
    "feDisplacementMap",
    "svg-filter",
    "frosted-glass",
    "lens",
    "chromatic-aberration",
    "web-component",
    "ui",
    "effect"
  ],
  "author": "Eamon Liu (https://github.com/eamonliu)",
  "license": "MIT",
  "homepage": "https://github.com/eamonliu/vitrio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eamonliu/vitrio.git"
  },
  "bugs": {
    "url": "https://github.com/eamonliu/vitrio/issues"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  }
}
